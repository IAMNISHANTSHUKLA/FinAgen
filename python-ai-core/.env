# ─── FinAgentX Environment Configuration ───

# Cerebras LLM API
CEREBRAS_API_KEY=csk-pw9x26rx5r5fynwfv93w4t2p9pycm6kn2rrx9j4vdwfxrph8
CEREBRAS_MODEL=llama-4-scout-17b-16e-instruct
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_CHEAP_MODEL=llama-4-scout-17b-16e-instruct

# Judge Model (separate from agent — Fix #4)
JUDGE_MODEL=llama-4-scout-17b-16e-instruct

# Service
SERVICE_NAME=finagentx-ai-core
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Redis
REDIS_URL=redis://localhost:6379/0

# Weaviate
WEAVIATE_URL=http://localhost:8081
WEAVIATE_COLLECTION=FinancialDocuments

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# MinIO / S3 (Audit WORM Storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=finagentx
MINIO_SECRET_KEY=finagentx-secret

# JWT Auth (leave empty for dev mode — auth disabled)
JWT_PUBLIC_KEY=

# RAG Pipeline
RAG_ALPHA=0.75
RAG_INITIAL_TOP_K=20
RAG_RERANK_TOP_K=8
RAG_TOKEN_BUDGET=4096
CASCADE_CONFIDENCE_THRESHOLD=0.7

# Agent Guardrails
AGENT_MAX_STEPS=10
AGENT_TIMEOUT_SECONDS=60.0
AGENT_PER_TOOL_TIMEOUT=10.0

# Embedding
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_VERSION=1.0.0
EMBEDDING_DIM=384
